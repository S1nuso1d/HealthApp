# Скопируй в `.env` и подставь свои значения.
# Положи файл сюда: `HealthApp-back/backend/.env` (рядом с папкой `app/`), либо в `HealthApp-back/.env`.

# --- Почта: код подтверждения при регистрации ---
# Пока SMTP_HOST пустой, письма НЕ отправляются — код выводится в консоль сервера
# строкой вида: [HealthApp mail dev] Код подтверждения для user@mail.com: 123456
#
# Mail.ru: в SMTP_PASSWORD нужен «ПАРОЛЬ ПРИЛОЖЕНИЯ» для внешних программ, НЕ пароль входа в почту.
# Создание: https://help.mail.ru/mail/security/protection/external
SMTP_HOST=smtp.mail.ru
SMTP_PORT=587
SMTP_USER=you@mail.ru
SMTP_PASSWORD=
SMTP_FROM=you@mail.ru
SMTP_USE_TLS=true
# Если 587 не работает, попробуй Mail.ru с SSL: SMTP_PORT=465 и SMTP_USE_SSL=true (SMTP_USE_TLS=false)
SMTP_USE_SSL=false
REGISTRATION_CODE_TTL_MINUTES=15

# Примеры провайдеров (смотри их документацию по SMTP):
# Gmail: smtp.gmail.com, порт 587, TLS; нужен «пароль приложения», не обычный пароль.
# Mail.ru: smtp.mail.ru — обязателен пароль приложения для SMTP (см. ссылку выше).
# Yandex: smtp.yandex.ru
